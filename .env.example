# .env.example — copy to .env and fill in your values
# Django never reads this file directly; the app reads from actual environment
# variables. In Docker Compose the .env file is loaded via env_file: .env.
#
# Generate a new SECRET_KEY:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=django-insecure-replace-this-with-a-secure-random-key
DEBUG=True

# ── Hosts ─────────────────────────────────────────────────────────────────────
# Comma-separated. Use * for development; lock down in production.
ALLOWED_HOSTS=*

# ── Timezone ──────────────────────────────────────────────────────────────────
TIME_ZONE=America/Lima

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL (production/recommended):
DB_ENGINE=django.db.backends.postgresql
DB_NAME=attendance_db
DB_USER=attendance_user
DB_PASSWORD=change-me-secure-password
DB_HOST=127.0.0.1
DB_PORT=5432
DB_CONN_MAX_AGE=60

# SQLite fallback (development only — uncomment and set DB_ENGINE):
# DB_ENGINE=django.db.backends.sqlite3

# ── Audio (headless / Docker) ─────────────────────────────────────────────────
# Set to "dummy" inside Docker or on any server without a sound card.
# The kiosk uses Web Audio API (browser-side) for chimes; server-side pygame
# is only used for local beep feedback — dummy mode silences it gracefully.
SDL_AUDIODRIVER=dummy
SDL_VIDEODRIVER=dummy

# ── Django admin URL (optional hardening) ────────────────────────────────────
# ADMIN_URL=admin/
